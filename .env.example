# Copy this file to .env and set your host paths.
#
# Windows (WSL2) example: /mnt/c/Users/YourName/Nextcloud
# Linux example:          /home/yourname/Nextcloud

# Path to your Nextcloud directory
NEXTCLOUD_PATH=

# Path to your Code directory
CODE_PATH=

# Qdrant API key. Required by docker-compose.yml so the vector DB is not
# accessible unauthenticated from other containers on the Docker network.
# Generate one with: openssl rand -hex 32
QDRANT_API_KEY=

# API authentication key. All endpoints (except the health check) require:
#   Authorization: Bearer <this value>
# Generate one with: openssl rand -hex 32
# Leave empty only if you explicitly enable local-only insecure mode below.
API_KEY=

# Comma-separated allowed CORS origins. Leave empty to disable cross-origin browser access.
# Example: CORS_ORIGINS=https://chat.example.com,https://app.example.com
CORS_ORIGINS=

# Local development escape hatch.
# Set to true only when the API is bound for local-only use and you intentionally
# want to run without any authentication.
# ALLOW_INSECURE_LOCALONLY=true

# Override the host port the API is published on (useful if 8000 is already in use)
# API_PORT=8001

# Override if Ollama is not running on the default port or host
# OLLAMA_BASE_URL=http://localhost:11434

# "strict" (default): answer only from retrieved context; refuse if nothing found
# "augmented": use context when found, fall back to model knowledge otherwise
# RAG_MODE=strict

# HuggingFace token — optional but avoids rate limits when downloading models
# Get one at https://huggingface.co/settings/tokens
# HF_TOKEN=

# Set to 1 to log per-stage timings (embed, recall, rerank, generate) on every request
# RAG_TIMING=0

# Set to false to skip MMR diversification and avoid fetching vectors from Qdrant (faster)
# MMR_ENABLED=true

# Local Ollama generation capacity. CPU-only or low-VRAM systems should usually keep this at 1.
# Strong GPUs may tolerate 2 after measuring tail latency.
# GENERATION_CONCURRENCY_LIMIT=1

# Keyword/BM25 guardrails. If the corpus exceeds these limits, vector retrieval still works
# and the in-memory keyword index disables itself to protect API memory/CPU.
# KEYWORD_SEARCH_ENABLED=true
# KEYWORD_INDEX_MAX_DOCS=100000
# KEYWORD_INDEX_MAX_TOKENS=5000000
# KEYWORD_MIN_QUERY_TOKENS=1
# KEYWORD_MAX_QUERY_TOKENS=32

# Web UI authentication
# Manage users: docker exec -it rag-api python manage_users.py add <username>
# Session lifetime in hours (default: 8)
# SESSION_EXPIRY_HOURS=8

# Chat request safety limits
# MAX_CHAT_MESSAGES=200
# MAX_CHAT_CONTENT_ITEMS=32
# MAX_CHAT_MESSAGE_CHARS=8000
# MAX_CHAT_TOTAL_CHARS=120000
# MAX_CHAT_QUESTION_CHARS=12000
# MAX_MODEL_NAME_CHARS=128

# Shared secret for server-to-server /v1/retrieve calls (used by code-assistant v4 context injection).
# Leave unset to disable the endpoint. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# RAG_INTERNAL_TOKEN=
